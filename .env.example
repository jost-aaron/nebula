# Copy to .env only for the deployment Compose example. Never commit .env.
# Bind to 127.0.0.1 behind a same-host reverse proxy. Use 0.0.0.0 deliberately
# for direct LAN access and protect the network accordingly.
NEBULA_BIND_ADDRESS=127.0.0.1
NEBULA_PORT=5173

# Linux example paths and numeric container identity. The macOS and Windows
# operator launchers generate platform-native absolute paths automatically.
# Keep Windows data/state on local NTFS storage, not a network or FAT volume.
NEBULA_UID=1000
NEBULA_GID=1000
NEBULA_DATA_PATH=/srv/nebula/data
NEBULA_CONTENT_PATH=/srv/nebula/content
NEBULA_BACKUP_PATH=/srv/nebula/backups

# Account auth is always active. These settings govern only the legacy
# service/admin token. Generate a long random value if enabling it.
NEBULA_REQUIRE_AUTH=false
NEBULA_API_TOKEN=
NEBULA_AUTH_ALLOW_LOCALHOST=false

# Disable temporary first-run guest access for a conservative deployment.
NEBULA_FIRST_RUN_GUEST_ENABLED=false
NEBULA_GUEST_SESSION_TTL_MS=28800000

# Comma-separated exact origins only; do not use '*'.
NEBULA_CORS_ALLOWED_ORIGINS=
NEBULA_VITE_ALLOWED_HOSTS=
NEBULA_VITE_HMR=false
NEBULA_EXTERNAL_HTTPS=false

# The pinned Tailscale companion starts dormant. Owners enable it from Settings
# / Remote Access. Keep the state private; an optional mode-0600 auth-key file
# may bootstrap unattended enrollment and should be emptied after enrollment.
# Operator launchers generate nebula-<system-hostname>; set it explicitly when
# using Compose directly.
NEBULA_TAILSCALE_HOSTNAME=nebula-media-host
NEBULA_TAILSCALE_FQDN=
NEBULA_TAILSCALE_UI_ENABLED=true
NEBULA_TAILSCALE_INTERACTIVE_LOGIN=true
NEBULA_TAILSCALE_STATE_PATH=/srv/nebula/tailscale/state
NEBULA_TAILSCALE_AUTHKEY_FILE=/srv/nebula/tailscale/authkey

# Experimental media-cluster trust layer. Leave disabled for normal standalone
# deployments. The endpoint must be this node's exact Tailscale Serve HTTPS
# origin; role is coordinator, shard, or hybrid. The fixed userspace HTTP proxy
# is supplied by Compose and is not operator-configurable.
NEBULA_CLUSTER_ENABLED=false
NEBULA_CLUSTER_ENDPOINT=
NEBULA_CLUSTER_NODE_NAME=Nebula
NEBULA_CLUSTER_ROLE=hybrid

# Optional metadata credentials. Prefer saving TMDB through owner Settings.
TMDB_API_TOKEN=
GOOGLE_VISION_API_KEY=

NEBULA_AUDIT_RETENTION_DAYS=90
NEBULA_AUDIT_MAX_EVENTS=10000
